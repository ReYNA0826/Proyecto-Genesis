# Copia este archivo como .env.local (está en .gitignore — NUNCA se commitea)
# y pega las llaves reales. Las mismas dos variables van en Vercel:
# Project → Settings → Environment Variables (Production + Preview + Development).

# ElevenLabs — para "Solo voz" en las oficinas (API key de tu cuenta ElevenLabs)
ELEVENLABS_API_KEY=

# HeyGen — para el avatar streaming en vivo (HeyGen → Settings → API)
HEYGEN_API_KEY=
